# Copy to .env.local at repo root.
# Local development uses the docker-compose Postgres + Redis.

# Postgres (local Docker — port 5435 to avoid clash with native Postgres on 5432-5434)
DATABASE_URL="postgresql://vrs:vrs@localhost:5435/vrs?schema=public"

# Redis (local Docker) — used by BullMQ
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="dev-secret-replace-in-production-min-32-chars"
AUTH_TRUST_HOST="true"

# Anthropic — for Vera. Paste your key here for local dev.
ANTHROPIC_API_KEY=""

# Azure Blob Storage (production). For local dev, report files write to ./tmp.
# AZURE_STORAGE_ACCOUNT=""
# AZURE_STORAGE_CONTAINER="reports"
